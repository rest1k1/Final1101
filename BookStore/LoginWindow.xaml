<Window x:Class="BookStore.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookStore"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800" FontFamily="Calibri"
        WindowStartupLocation="CenterScreen"
        Background="White" MinWidth="600" MinHeight="400"
        Icon="/Images/icon_win.ico">

    <Grid Margin="20" Background="#FFFFFF">
        
        <StackPanel>
            
            <TextBlock Text="Логин"/>
            <TextBox x:Name="LoginBox" Margin="0,5,0,10" TabIndex="1"/>

            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,5,0,10" TabIndex="2"/>

            <Button Background="#B8860B" Foreground="#FFFFFF"
                    Content="Войти" Click="Login_Click" Height="35" TabIndex="3"/>
            
            <Button Content="Назад"
                    Background="#B8860B" Foreground="#FFFFFF"
                    TabIndex="4"
                    Height="35"
                    Click="Back_Click"
                    VerticalAlignment="Bottom" Margin="0,5,0,10"/>
            
        </StackPanel>
        
    </Grid>
    
</Window>
    
