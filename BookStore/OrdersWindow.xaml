<Window x:Class="BookStore.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Работа с заказами"
        Height="600"
        Width="1400"
        MinHeight="500"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Icon="/Images/icon_win.ico">

    <Grid Margin="10" Background="#FFFFFF">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10"
                CornerRadius="5"
                BorderBrush="#D89A1D"
                BorderThickness="1"
                Margin="0,0,0,10">

            <StackPanel Orientation="Horizontal" Background="#FFFFFF">

                <TextBlock Text="Номер заказа:"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>

                <TextBox x:Name="SearchBox"
                         Width="180"
                         Height="30"
                         Margin="10,0,0,0"/>

                <Button Content="Найти"
                        Width="120"
                        Height="30"
                        Margin="10,0,0,0"
                        Background="#B8860B"
                        Foreground="#FFFFFF"
                        Click="SearchButton_Click"/>
                <Button Content="Сбросить"
                        Width="120"
                        Height="30"
                        Margin="10,0,0,0"
                        Background="#B8860B"
                        Foreground="#FFFFFF"
                        Click="ResetButton_Click"/>

            </StackPanel>

        </Border>

        <DataGrid x:Name="OrdersGrid"
                  Background="#FFFFFF"
                  BorderBrush="#D89A1D"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single">

            <DataGrid.Columns>

                <DataGridTextColumn Header="№ заказа"
                                    Binding="{Binding OrderNumber}"
                                    Width="100"
                                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Артикул заказа"
                                    Binding="{Binding Article}"
                                    Width="250"
                                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Дата заказа"
                                    Binding="{Binding OrderDate}"
                                    Width="150"
                                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Дата доставки"
                                    Binding="{Binding DeliveryDate}"
                                    Width="150"/>

                <DataGridComboBoxColumn Header="Статус"
                                        Width="150"
                                        SelectedItemBinding="{Binding Status}">

                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="{x:Type sys:String}"
                                 xmlns:sys="clr-namespace:System;assembly=mscorlib">

                            <sys:String>Новый</sys:String>
                            <sys:String>В обработке</sys:String>
                            <sys:String>Завершен</sys:String>

                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>

                </DataGridComboBoxColumn>

                <DataGridTextColumn Header="Клиент"
                                    Binding="{Binding ClientName}"
                                    Width="250"
                                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Код получения"
                                    Binding="{Binding CodeForReceive}"
                                    Width="150"
                                    IsReadOnly="True"/>

            </DataGrid.Columns>

        </DataGrid>

        <Grid Grid.Row="2"
              Margin="0,10,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Назад"
                    Height="55"
                    Margin="0,0,5,0"
                    Background="#B8860B"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    Click="Back_Click"/>

            <Button Grid.Column="2"
                    Content="Сохранить изменения"
                    Height="55"
                    Margin="5,0,0,0"
                    Background="#B8860B"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    Click="SaveButton_Click"/>

        </Grid>

    </Grid>

</Window>